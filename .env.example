# Copy to .env and adjust as needed.

# HTTP server
PORT=3000
HOST=0.0.0.0

# Store driver: auto | redis | memory
#   auto   -> try Redis, fall back to in-memory (default)
#   redis  -> require Redis (fail to start if unreachable)
#   memory -> in-memory only (data lost on restart, single instance)
STORE_DRIVER=auto
REDIS_URL=redis://127.0.0.1:6379

# Secret used to sign device "poison" tokens. Set a long random value in prod;
# if unset, an ephemeral one is generated at startup (poison resets on restart).
# Generate one with (PowerShell):
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
JWT_SECRET=

# Guard rails
MAX_CIPHERTEXT_BYTES=65536
MAX_VIEW_LIMIT=100
MIN_TTL_SECONDS=60
MAX_TTL_SECONDS=2592000
